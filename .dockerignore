**/__pycache__/
**/.pytest_cache/
**/.mypy_cache/
**/.ruff_cache/
**/node_modules/
**/.venv/
**/venv/
**/*.egg-info/
**/dist/
**/build/
legba/state/
legba/persona_input/
legba/persona_output/
legba/minio_data/
legba/.env
**/*.log
